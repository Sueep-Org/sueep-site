// Sueep internal ERP — PostgreSQL in production (Vercel/Neon). Local: Docker Postgres or Neon dev branch.
// Money fields are integer cents.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  /// Pooled URL (Neon: hostname contains "-pooler") — app queries & serverless
  url       = env("DATABASE_URL")
  /// Direct URL (Neon: no "-pooler") — `prisma migrate` / CLI; set same as url if not using Neon pooler
  directUrl = env("DIRECT_URL")
}

model Project {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// COMMERCIAL | RESIDENTIAL
  segment String @default("COMMERCIAL")
  /// ACTIVE | ON_HOLD | COMPLETE | ARCHIVED
  status  String @default("ACTIVE")

  /// Primary / job-start date shown on PM dashboard
  projectDate DateTime?
  /// Target end / handoff — drives calendar span & Gantt bar end (optional)
  projectEndDate DateTime?

  jobTitle    String
  supervisor  String?
  description String?

  percentDone     Float @default(0)
  percentInvoiced Float @default(0)

  /// BILLING | INACTIVE | INVOICE_PAID — manually set per project
  billingStatus String?

  contractValueCents Int?

  estMaterialCents Int?
  estTravelCents   Int?
  estLaborCents    Int?

  actualLaborCents    Int?
  actualMaterialCents Int?
  actualTravelCents   Int?

  estHours    Float?
  actualHours Float?

  /// Estimated duration in days. Actual days worked is computed from labor
  /// logs (distinct dates with a LaborEntry), not stored.
  estimatedDays Int?

  /// Optional link to a Building (set for janitorial turnover projects)
  buildingId String?
  building   Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)

  /// Optional link to the originating TurnoverRequest (set for janitorial unit projects)
  turnoverRequestId String?
  turnoverRequest   TurnoverRequest? @relation(fields: [turnoverRequestId], references: [id], onDelete: Cascade)

  /// Set for projects auto-generated by a RecurringContract. The billing
  /// project for a period has this set with turnoverRequestId null; unit
  /// projects for that period have both set.
  recurringContractPeriodId String?
  recurringContractPeriod   RecurringContractPeriod? @relation(fields: [recurringContractPeriodId], references: [id], onDelete: SetNull)

  laborEntries LaborEntry[]
  materialEntries MaterialEntry[]
  distanceEntries DistanceEntry[]
  workOrders ProjectWorkOrder[]
  workOrderAttachments ProjectWorkOrderAttachment[]
  images ProjectImage[]
  changeOrders ProjectChangeOrder[]
  contacts ProjectContact[]
  contractorAssignments ContractorAssignment[]
  laborAssignments ProjectLaborAssignment[]
  checklistItems ProjectChecklistItem[]
  unitTurnoverChecklist UnitTurnoverChecklist?
  workOrderRecord ProjectWorkOrderRecord?
  qualityChecks QualityCheck[]
  dailySafetyChecks DailySafetyCheck[]
  contracts ProjectContract[]
  safetyIncidents SafetyIncident[]
  sov ProjectSOV?
  dayAssignments ProjectDayAssignment[]
  workerDayAssignments ProjectWorkerDayAssignment[]
  notes ProjectNote[]

  /// Link to the ERP user assigned as supervisor (used to filter supervisor dashboard)
  supervisorUserId String?
  supervisorUser   ErpUser? @relation(fields: [supervisorUserId], references: [id], onDelete: SetNull)

  /// Per-project pricing package (used for real estate; overrides global default)
  pricingPackage Json?

  /// HubSpot Deal record id (sync from CRM). One ERP project per deal until multi-job-per-deal is modeled.
  hubspotDealId     String? @unique
  hubspotPipelineId String?
  hubspotStageId    String?
  hubspotOwnerId    String?
  hubspotOwnerName  String?
  hubspotOwnerEmail String?

  /// Sales commission (flat 10% of contractValueCents) is marked paid here.
  /// The salesperson defaults to matching hubspotOwnerEmail/hubspotOwnerName
  /// to an Employee, but that match can be wrong (e.g. the HubSpot deal
  /// owner is an estimator, not the salesperson who should get credit) —
  /// commissionEmployeeId lets that be overridden per project.
  commissionPaidAt    DateTime?
  commissionEmployeeId String?
  commissionEmployee   Employee? @relation(fields: [commissionEmployeeId], references: [id], onDelete: SetNull)

  @@index([segment])
  @@index([commissionEmployeeId])
  @@index([status])
  @@index([projectDate])
  @@index([recurringContractPeriodId])
}

model Building {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name    String
  builder String?
  address String
  pmName  String?
  pmEmail String?
  pmPhone String?
  pricingPackage Json?

  turnoverRequests      TurnoverRequest[]
  contractorAssignments ContractorAssignment[]
  projects              Project[]
  recurringContract     RecurringContract?

  @@index([name])
}

enum TurnoverRequestType {
  TURNOVER
  REGULAR
}

enum TurnoverRequestStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  QUALITY_CHECK
  APPROVED
}

model TurnoverRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buildingId String
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  requestType TurnoverRequestType @default(TURNOVER)
  unitNumber  String?
  bedrooms    Int?
  bathrooms   Int?

  fullPaint           Boolean @default(false)
  touchUpPaint        Int?     @default(0)
  fullClean           Boolean @default(false)
  carpetCleaning      Boolean @default(false)
  materialsAdditional Boolean @default(false)
  ceilingPaint        Boolean @default(false)

  otherWork        Boolean @default(false)
  otherDescription String?
  /// Manually entered price for the "Other" line item, in cents.
  otherCents       Int?

  startDate DateTime?
  endDate   DateTime?
  priceCents Int?
  approvedPriceCents Int?
  pmSignatureUrl String?
  pmSignedAt DateTime?
  completedAt DateTime?
  invoiceGeneratedAt DateTime?
  invoiceUrl String?
  /// NOT_BILLED | BILLED | PAID
  billingStatus String @default("NOT_BILLED")

  createdBy String?
  status    TurnoverRequestStatus @default(PENDING)

  laborAssignments       LaborAssignment[]
  qualityChecks          QualityCheck[]
  projects               Project[]

  @@index([buildingId])
  @@index([status])
  @@index([requestType])
}

/// A flat monthly (subscription-style) janitorial contract for a Building,
/// as opposed to one-off per-job pricing. Each month, a scheduled job
/// generates a RecurringContractPeriod: one billing Project holding the
/// flat revenue, plus one TurnoverRequest+Project pair per enrolled unit
/// for cost tracking — see src/lib/erp/recurringContracts.ts.
model RecurringContract {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  buildingId String   @unique
  building   Building @relation(fields: [buildingId], references: [id], onDelete: Cascade)

  monthlyRateCents Int
  /// Day of month (1-28) generation runs for this contract
  billingDayOfMonth Int
  /// ACTIVE | PAUSED | ENDED
  status    String    @default("ACTIVE")
  startDate DateTime
  endDate   DateTime?
  notes     String?

  /// Salesperson who gets commission credit — manually assigned, since
  /// recurring contracts are created directly in the ERP rather than
  /// synced from a HubSpot deal with an owner.
  commissionEmployeeId String?
  commissionEmployee   Employee? @relation(fields: [commissionEmployeeId], references: [id], onDelete: SetNull)

  units   RecurringContractUnit[]
  periods RecurringContractPeriod[]

  @@index([status])
  @@index([commissionEmployeeId])
}

model RecurringContractUnit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  recurringContractId String
  recurringContract   RecurringContract @relation(fields: [recurringContractId], references: [id], onDelete: Cascade)

  unitNumber   String
  bedrooms     Int?
  bathrooms    Int?
  isCommonArea Boolean @default(false)

  /// Which service lines run each month for this unit — drives the
  /// auto-generated TurnoverRequest's flags
  fullClean      Boolean @default(true)
  carpetCleaning Boolean @default(false)

  /// Soft-remove so past generated periods keep their unit history intact
  active Boolean @default(true)

  @@unique([recurringContractId, unitNumber])
  @@index([recurringContractId])
}

model RecurringContractPeriod {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  recurringContractId String
  recurringContract   RecurringContract @relation(fields: [recurringContractId], references: [id], onDelete: Cascade)

  /// First of the billing month this period covers
  periodStart      DateTime
  billingProjectId String   @unique

  /// Recurring-contract commission (5% of ACV months 1-12, 2% months
  /// 13-24, $0 after) is computed at read time from monthlyRateCents and
  /// elapsed months — only paid status needs to be persisted per period.
  commissionPaidAt DateTime?

  projects Project[]

  @@unique([recurringContractId, periodStart])
}

model LaborAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  turnoverRequestId String
  turnoverRequest   TurnoverRequest @relation(fields: [turnoverRequestId], references: [id], onDelete: Cascade)

  laborerId String
  laborer   Employee @relation(fields: [laborerId], references: [id], onDelete: Cascade)

  role          String?
  assignedDate  DateTime?
  startDate     DateTime?
  endDate       DateTime?
  notes         String?
  materialsUsed Json?

  @@index([turnoverRequestId])
  @@index([laborerId])
}

model QualityCheck {
  id                   String   @id @default(cuid())
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  turnoverRequestId    String?
  turnoverRequest      TurnoverRequest? @relation(fields: [turnoverRequestId], references: [id], onDelete: Cascade)

  projectId            String?
  project              Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  supervisorName       String
  supervisorSignatureUrl String?
  pmApproval           Boolean @default(false)
  evidencePhotos       Json?
  notes                String?

  @@index([turnoverRequestId])
  @@index([projectId])
}

model DailySafetyCheck {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  checkDate           DateTime
  supervisorName      String
  groupPhotoData           Bytes?
  groupPhotoMimeType       String?
  groupPhotoUploadedAt     DateTime?
  siteArrivalPhotoData     Bytes?
  siteArrivalPhotoMimeType String?
  siteArrivalPhotoUploadedAt DateTime?
  approvedForWork          Boolean  @default(false)
  approvedAt               DateTime?
  notes                    String?

  workers   SafetyCheckWorker[]
  incidents SafetyIncident[]

  @@index([projectId])
  @@index([checkDate])
}

model SafetyCheckWorker {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  safetyCheckId String
  safetyCheck   DailySafetyCheck @relation(fields: [safetyCheckId], references: [id], onDelete: Cascade)

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  workerName String
  hasVest    Boolean @default(false)
  hasHardHat Boolean @default(false)
  hasBoots   Boolean @default(false)
  hasUniform       Boolean @default(false)
  photoData        Bytes?
  photoMimeType    String?
  photoUploadedAt  DateTime?
  passed         Boolean @default(false)
  notes          String?

  incidents SafetyIncident[]

  @@index([safetyCheckId])
  @@index([employeeId])
}

model SafetyIncident {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  safetyCheckWorkerId String
  safetyCheckWorker   SafetyCheckWorker @relation(fields: [safetyCheckWorkerId], references: [id], onDelete: Cascade)

  safetyCheckId String
  safetyCheck   DailySafetyCheck @relation(fields: [safetyCheckId], references: [id], onDelete: Cascade)

  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  workerName String
  checkDate  DateTime

  /// OPEN | RESOLVED | ESCALATED
  status             String    @default("OPEN")
  resolvedAt         DateTime?
  escalatedAt        DateTime?
  notificationSentAt DateTime?
  escalationSentAt   DateTime?

  /// Running total of violations for this worker at time of creation
  violationCount Int @default(1)

  @@index([projectId])
  @@index([employeeId])
  @@index([status])
  @@index([safetyCheckId])
  @@index([safetyCheckWorkerId])
}

model ProjectWorkOrder {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title         String
  location      String?
  requestedBy   String?
  priority      String   @default("MEDIUM")
  dueDate       DateTime?
  scopeDetails  String?
  specifications String?
  supportInfo   String?
  photoUrls     Json?
  @@index([projectId, createdAt])
  @@index([priority])
  @@index([dueDate])
}

model ProjectWorkOrderAttachment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  filename String
  mimeType String
  size     Int
  data     Bytes

  @@index([projectId])
}

model ProjectChecklistItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// The calendar date this item belongs to (stored as midnight UTC)
  date      DateTime
  title     String
  completed Boolean  @default(false)
  notes     String?

  @@index([projectId, date])
}

/// One persistent work order record per project — editable, resendable
model ProjectWorkOrderRecord {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  projectName String
  siteAddress String?
  contacts    String?
  startDate   String?
  serviceType String?
  notes       String?

  /// Denormalized for display — set when email is sent
  lastSentToName String?
  lastSentAt     DateTime?
}

model ProjectImage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  imageUrl  String
  caption   String?
  uploadedBy String?
  takenAt   DateTime?

  @@index([projectId, createdAt])
}

model ProjectChangeOrder {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  title              String
  description        String?
  requestedBy        String?
  supervisor         String?
  status             String   @default("DRAFT")
  requestedDate      DateTime? @default(now())
  startDate          DateTime?
  billingStatus      String?
  percentInvoiced    Int      @default(0)
  completedAt        DateTime?
  estimatedCostCents  Int?
  estimatedDays       Int?
  reason              String?
  resolutionNotes     String?
  contractValueCents  Int?
  estMaterialCents    Int?
  estTravelCents      Int?
  estLaborCents       Int?
  actualLaborCents    Int?
  actualMaterialCents Int?
  actualTravelCents   Int?
  estHours            Float?
  actualHours         Float?
  estLaborers         Int?
  estSupervisors      Int?

  laborers        ProjectChangeOrderLaborer[]
  contracts       ChangeOrderContract[]
  materialEntries ChangeOrderMaterialEntry[]
  contractorAssignments ChangeOrderContractorAssignment[]

  @@index([projectId, createdAt])
  @@index([status])
}

/// A contractor logged on a change order — same idea as ContractorAssignment
/// on Project, but scoped to the CO instead.
model ChangeOrderContractorAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  changeOrderId String
  changeOrder   ProjectChangeOrder @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)

  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  role         String?
  assignedDate DateTime?
  startDate    DateTime?
  endDate      DateTime?
  notes        String?
  costCents    Int?

  @@index([changeOrderId])
  @@index([contractorId])
}

model ProjectChangeOrderLaborer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  changeOrderId String
  changeOrder   ProjectChangeOrder @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)

  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  name            String
  role            String?
  workDate        DateTime @default(now())
  hours           Float    @default(0)
  /// Clock-in time as "HH:MM" (24h), e.g. "08:00". Null for entries logged before this field existed.
  clockIn         String?
  /// Cents per hour (e.g. $28.84/hr → 2884)
  hourlyRateCents Int      @default(0)
  taskDescription String?

  qualityRating String?
  qualityNotes  String?
  completed     Boolean @default(false)

  @@index([changeOrderId])
}

model ProjectContract {
  id                   String    @id @default(cuid())
  createdAt            DateTime  @default(now())
  projectId            String
  project              Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  signingStatus        String    @default("SIGNED")
  customerEmail        String?
  docusealSubmissionId Int?      @unique
  signedAt             DateTime?
  signedDocumentUrl    String?

  @@index([projectId])
}

model ChangeOrderContract {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())

  changeOrderId String
  changeOrder   ProjectChangeOrder @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)

  contractPdfFilename  String?
  docusealTemplateId   Int?
  signingStatus        String?
  customerEmail        String?
  docusealSubmissionId Int?
  signedAt             DateTime?
  signedDocumentUrl    String?

  @@index([changeOrderId])
  @@index([docusealSubmissionId])
  @@index([docusealTemplateId])
}

model ProjectContact {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  fullName String
  role     String?
  company  String?
  email    String?
  phone    String?
  notes    String?
  hubspotContactId String?
  /// HUBSPOT | MANUAL
  source   String   @default("MANUAL")
  isPrimary Boolean @default(false)

  @@index([projectId, createdAt])
  @@index([projectId, source])
  @@index([email])
  @@index([phone])
  @@unique([projectId, hubspotContactId])
}

model LaborEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  employeeId String?
  employee   Employee? @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  workDate DateTime

  workerName String
  role       String?
  hours      Float
  /// Clock-in time as "HH:MM" (24h), e.g. "08:00". Null for entries logged before this field existed.
  clockIn    String?
  /// Cents per hour (e.g. $28.84/hr → 2884)
  hourlyRateCents Int

  taskDescription String?

  /// Optional link to a ProjectSOVItem (replaces taskDescription when set)
  sovItemId String?
  sovItem   ProjectSOVItem? @relation(fields: [sovItemId], references: [id], onDelete: SetNull)

  qualityRating String?
  qualityNotes  String?

  /// Location when entry was created (latitude)
  locationLatitude  Float?
  /// Location when entry was created (longitude)
  locationLongitude Float?
  /// Accuracy of location in meters
  locationAccuracy  Float?
  /// Timestamp when location was last captured
  lastLocationAt    DateTime?

  @@index([projectId])
  @@index([employeeId])
  @@index([workDate])
}

model MaterialEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  usedOn DateTime
  /// CLEANING_PRODUCTS | PAINT
  category String
  itemName  String
  quantity  Float?
  unit      String?
  costCents Int
  notes     String?

  @@index([projectId])
  @@index([usedOn])
  @@index([category])
}

model DistanceEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  travelDate DateTime
  miles      Float
  personName String?
  notes      String?

  @@index([projectId])
  @@index([travelDate])
}

/// ADMIN | PROJECT_MANAGER | SUPERVISOR | ESTIMATION | EMPLOYEE
model ErpUser {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  firebaseUid String   @unique
  email       String   @unique
  role        String   @default("EMPLOYEE")

  supervisorProjects Project[]
  dayAssignments     ProjectDayAssignment[]
  projectNotes       ProjectNote[]

  @@index([firebaseUid])
}

/// A team-visible, timestamped note on a project (e.g. "had to pause cleaning
/// due to maintenance needed before we finish the unit") — an append-only log,
/// not a single editable description. Shown in the project's Overview tab.
model ProjectNote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  body String

  /// Snapshot of the author's name at post time, so the note stays readable
  /// even if their ERP account is later removed.
  authorName   String
  authorUserId String?
  authorUser   ErpUser? @relation(fields: [authorUserId], references: [id], onDelete: SetNull)

  @@index([projectId])
}

/// A supervisor's planned coverage of a project on a specific future day —
/// distinct from LaborEntry (which records work that already happened).
/// Lets a PM click a day on the schedule calendar, pick a project, and
/// assign the supervisor who'll be there, before any labor is logged.
model ProjectDayAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// The calendar date this assignment is for (stored as midnight UTC)
  date DateTime

  /// Optional "HH:MM" (24h) local time, e.g. "08:00". All-day event on the
  /// calendar invite if either time is unset.
  startTime String?
  endTime   String?

  supervisorUserId String
  supervisorUser   ErpUser @relation(fields: [supervisorUserId], references: [id], onDelete: Cascade)

  @@unique([projectId, date])
  @@index([date])
  @@index([supervisorUserId])
}

/// A worker planned to be on a project on a future day, before any labor is
/// logged — same idea as ProjectDayAssignment but for crew (Employee) rather
/// than supervisors, and multiple per project/day since a crew has more than
/// one person. No notification is sent when these are created (unlike the
/// supervisor calendar invite) — may be added later.
model ProjectWorkerDayAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  /// The calendar date this assignment is for (stored as midnight UTC)
  date DateTime

  @@unique([projectId, employeeId, date])
  @@index([date])
  @@index([employeeId])
}

model Employee {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  firstName String
  lastName  String
  email     String? @unique
  phone     String?
  role      String?
  /// HOURLY | SALARY
  payType        String  @default("HOURLY")
  /// Cents per hour (e.g. $18.75 => 1875)
  hourlyPayCents Int?
  /// Annual salary in cents (e.g. $50,000 => 5000000)
  annualSalaryCents Int?

  /// Paid a fixed amount every month via the Offshore Payroll tab, not tied
  /// to logged hours — a distinct concept from HOURLY/SALARY payType.
  isOffshore Boolean @default(false)
  /// Fixed monthly pay in cents, only used when isOffshore is true.
  offshoreMonthlyRateCents Int?

  defaultProject String?
  /// ACTIVE | INACTIVE
  status String @default("ACTIVE")
  hireDate DateTime?
  notes    String?

  bankAccountType   String?
  bankAccountNumber String?
  bankRoutingNumber String?

  /// Social Security Number. Masked by default in the UI; only revealed
  /// on-demand via a role-gated endpoint (never shipped in the initial page load).
  ssn String?

  /// Array of document type labels required for compliance (e.g. ["I-9", "OSHA card"])
  requiredDocuments Json @default("[]")

  /// PASSED | FAILED | PENDING | NOT_DONE
  backgroundCheckStatus String? @default("NOT_DONE")

  laborEntries LaborEntry[]
  documents EmployeeDocument[]
  laborAssignments LaborAssignment[]
  projectLaborAssignments ProjectLaborAssignment[]
  workerDayAssignments ProjectWorkerDayAssignment[]
  changeOrderAssignments ProjectChangeOrderLaborer[]
  contracts EmployeeContract[]
  safetyCheckWorkers SafetyCheckWorker[]
  safetyIncidents SafetyIncident[]
  commissionProjects Project[]
  reimbursements Reimbursement[]
  recurringContractCommissions RecurringContract[]
  offshorePayrollPayments OffshorePayrollPayment[]

  @@index([status])
  @@index([defaultProject])
  @@index([hourlyPayCents])
  @@index([lastName, firstName])
}

/// Tracks whether an offshore employee's fixed monthly pay has been paid for
/// a given month. The rate itself isn't snapshotted here — Employee.offshoreMonthlyRateCents
/// is read live, since a rate change should apply going forward without
/// needing a "contract" concept the way recurring janitorial contracts do.
model OffshorePayrollPayment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  /// First of the paid month
  periodStart DateTime
  paidAt      DateTime?

  @@unique([employeeId, periodStart])
}

model EmployeeDocument {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  documentType String
  title        String?
  issuedAt     DateTime?
  expiresAt    DateTime?
  isVerified   Boolean  @default(false)
  fileUrl      String?
  fileData     Bytes?
  fileMimeType String?
  fileFilename String?
  notes        String?

  @@index([employeeId])
  @@index([documentType])
  @@index([expiresAt])
}

model Reimbursement {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  date       DateTime
  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  /// Who/what the expense was for (e.g. "J Centra - Miyanna Nelson"), not necessarily the employee being reimbursed
  companyOrTeam String
  description   String
  amountCents   Int

  receiptUrl      String?
  receiptData     Bytes?
  receiptMimeType String?
  receiptFilename String?

  /// Set once Finance has paid the employee back
  paidAt DateTime?

  @@index([employeeId])
  @@index([paidAt])
}

model Contractor {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name  String
  email String? @unique

  /// ACTIVE | INACTIVE
  status String @default("ACTIVE")

  /// Paperwork items required. Array of { label: string; url: string }.
  paperwork                  Json?
  paperworkUploadToken       String?   @unique
  paperworkUploadTokenExpiry DateTime?

  /// Token for the contractor info form link
  infoToken       String?   @unique
  infoTokenExpiry DateTime?

  /// Info collected from contractor via the info form
  contractorFullName String?
  address            String?
  dateOfBirth        String?
  ssn                String?
  bankAccountType    String?
  bankAccountNumber  String?
  bankRoutingNumber  String?
  phone              String?
  hasInsurance       Boolean?

  documents   ContractorDocument[]
  assignments ContractorAssignment[]
  contracts   ContractorContract[]
  changeOrderAssignments ChangeOrderContractorAssignment[]

  @@index([status])
  @@index([name])
}

model ContractorAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  /// Link to a building for site-level work (optional)
  buildingId String?
  building   Building? @relation(fields: [buildingId], references: [id], onDelete: SetNull)

  /// Link to a project for project-level work (optional)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  role         String?
  assignedDate DateTime?
  startDate    DateTime?
  endDate      DateTime?
  notes        String?
  costCents    Int?

  @@index([contractorId])
  @@index([buildingId])
  @@index([projectId])
}

model ProjectLaborAssignment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  role         String?
  assignedDate DateTime?
  startDate    DateTime?
  endDate      DateTime?
  notes        String?

  @@index([projectId])
  @@index([employeeId])
  @@unique([projectId, employeeId])
}

model ContractorDocument {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  label    String
  filename String
  mimeType String
  size     Int
  data     Bytes

  @@index([contractorId])
}

/// Job interest / onboarding intake from sueep.com (public form). Extend `responses` when questionnaire fields are finalized.
model CandidateApplication {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fullName  String
  email     String
  phone     String?

  /// Role or work type they are interested in (placeholder until full questionnaire).
  positionInterest String?

  additionalNotes String?

  /// Arbitrary fields keyed by future form labels or Google Form column IDs.
  responses Json?

  /// APPLIED | INTERVIEWING | ONBOARDING | DENIED
  status String @default("APPLIED")

  internalNotes String?

  /// Whether the candidate must provide bank account details on the portal
  bankAccountRequired Boolean @default(false)
  bankAccountType     String?
  bankAccountNumber   String?
  bankRoutingNumber   String?

  /// Instructions shown at the top of the candidate's paperwork upload portal.
  paperworkInstructions String?

  /// Paperwork items required for onboarding. Array of { label: string; url: string }.
  paperwork Json?

  /// Token emailed to the candidate so they can upload documents via the public portal (no ERP login required).
  paperworkUploadToken       String?   @unique
  paperworkUploadTokenExpiry DateTime?

  documents  CandidateDocument[]
  contracts  CandidateContract[]

  /// Stable code emailed to the applicant; optional Google Form prefill or Apps Script matches this to mark completion.
  questionnaireToken String? @unique
  questionnaireSentAt      DateTime?
  questionnaireCompletedAt DateTime?

  @@index([status])
  @@index([createdAt])
  @@index([email])
}

model CandidateDocument {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  candidateApplicationId String
  candidateApplication   CandidateApplication @relation(fields: [candidateApplicationId], references: [id], onDelete: Cascade)

  /// Matches the label in the paperwork JSONB array
  label    String
  filename String
  mimeType String
  size     Int
  data     Bytes

  @@index([candidateApplicationId])
}

model EmployeeContract {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())

  employeeId String
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  contractPdfFilename  String?
  docusealTemplateId   Int?
  signingStatus        String?
  signerEmail          String?
  docusealSubmissionId Int?
  signedAt             DateTime?
  signedDocumentUrl    String?

  @@index([employeeId])
  @@index([docusealSubmissionId])
  @@index([docusealTemplateId])
}

model ContractorContract {
  id           String   @id @default(cuid())
  createdAt    DateTime @default(now())

  contractorId String
  contractor   Contractor @relation(fields: [contractorId], references: [id], onDelete: Cascade)

  contractPdfFilename  String?
  docusealTemplateId   Int?
  signingStatus        String?
  signerEmail          String?
  docusealSubmissionId Int?
  signedAt             DateTime?
  signedDocumentUrl    String?

  @@index([contractorId])
  @@index([docusealSubmissionId])
  @@index([docusealTemplateId])
}

model CandidateContract {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  candidateId String
  candidate   CandidateApplication @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  contractPdfFilename  String?
  docusealTemplateId   Int?
  signingStatus        String?
  signerEmail          String?
  docusealSubmissionId Int?
  signedAt             DateTime?
  signedDocumentUrl    String?

  @@index([candidateId])
  @@index([docusealSubmissionId])
  @@index([docusealTemplateId])
}

model UnitTurnoverChecklist {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projectId String  @unique
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  propertyName    String?
  unitNumber      String?
  checklistDate   String?
  technicianNames String?
  startTime       String?
  endTime         String?

  photoBefore Boolean @default(false)
  photoAfter  Boolean @default(false)

  conditionScore Int?
  issues         String?

  addlPaintTouchUp      Boolean @default(false)
  addlFullRepaint       Boolean @default(false)
  addlCarpetCleaning    Boolean @default(false)
  addlMaintenanceRepair Boolean @default(false)
  addlTrashOut          Boolean @default(false)

  technicianSignature String?
  supervisorSignature String?

  /// Record<sectionId, { before: string[], after: string[] }>
  sectionPhotos Json @default("{}")
  /// Record<itemId, boolean> — completion state for each checklist item
  completedItems Json @default("{}")

  photos UnitChecklistPhoto[]
}

model UnitChecklistPhoto {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())

  checklistId String
  checklist   UnitTurnoverChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)

  sectionId   String
  photoType   String   // "before" | "after"
  filename    String
  mimeType    String
  size        Int
  data        Bytes
}

model AppSetting {
  key   String @id
  value String
}

model ProjectSOV {
  id        String         @id @default(cuid())
  projectId String         @unique
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  items     ProjectSOVItem[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model ProjectSOVItem {
  id                  String     @id @default(cuid())
  sovId               String
  sov                 ProjectSOV @relation(fields: [sovId], references: [id], onDelete: Cascade)
  order               Int        @default(0)
  description         String
  scheduledValueCents Int        @default(0)
  completed           Boolean    @default(false)
  /// NOT_BILLED | BILLED | PAID
  billingStatus       String     @default("NOT_BILLED")
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  laborEntries LaborEntry[]

  @@index([sovId])
}

model ChangeOrderMaterialEntry {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  changeOrderId String
  changeOrder   ProjectChangeOrder @relation(fields: [changeOrderId], references: [id], onDelete: Cascade)

  usedOn    DateTime
  category  String
  itemName  String
  quantity  Float?
  unit      String?
  costCents Int
  notes     String?

  @@index([changeOrderId])
  @@index([usedOn])
}
