# Firebase (for public authentication - REQUIRED)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Stripe (for payment processing - REQUIRED)
STRIPE_SECRET_KEY=sk_live_or_sk_test_your_secret_key
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_or_pk_test_your_publishable_key

# Database (Neon PostgreSQL - REQUIRED)
# Neon: use the *pooled* connection for DATABASE_URL (host contains "-pooler") and the *direct* for DIRECT_URL.
# Local Docker: use the same URL for both.
# Add &connect_timeout=15 if you see timeouts after idle (Neon scale-to-zero).
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ERP Session (Internal - REQUIRED)
# Uses Firebase authentication, so only needs JWT signing secret
# Generate with: openssl rand -hex 32
ERP_SESSION_SECRET=min-32-chars-random-use-openssl-rand-hex-32

# HubSpot (optional - uncomment to enable CRM sync)
# HUBSPOT_ACCESS_TOKEN=your_hubspot_private_app_token
# HUBSPOT_CLIENT_SECRET=your_hubspot_client_secret
# HUBSPOT_PIPELINE_STAGE_MAP={"postConstruction":{"pipelineId":"","stages":{"quoteApproved":"","workInProgress":"","workCompleted":"","billing":""}},"janitorial":{"pipelineId":"","stages":{"quoteApproved":"","workInProgress":"","workCompleted":"","walkthrough":"","proposal":"","activeTurnovers":""}},"realEstate":{"pipelineId":"","stages":{"quoteApproved":"","workInProgress":"","workCompleted":""}}}
# Deal property holding the post-construction project's real start date (see syncDealsToProjects.ts) — check which property is actually populated on real deals before setting this, property internal names can be misleading
# HUBSPOT_PROJECT_START_DATE_PROPERTY=fecha_de_inicio_del_contrato


#DocuSeal
# DOCUSEAL_API_KEY=your_key_here
# DOCUSEAL_API_URL=https://api.docuseal.com